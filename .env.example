# WhatsApp AI Enhancement Layer — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-random-32-char-string
AI_LAYER_PORT=5000

# ── Existing NestJS System (DO NOT CHANGE IF ALREADY RUNNING) ────────────────
# Point to the running NestJS API — we call it but never modify it
NESTJS_BASE_URL=http://localhost:3005/api
NESTJS_WEBHOOK_PATH=/webhooks/whatsapp

# ── Twilio (SAME credentials as existing system — shared) ─────────────────────
# Copy these from the existing .env — no need for separate Twilio account
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# ── OpenAI (NEW — for AI auto-replies) ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=300

# ── Redis (optional — uses DB=1 to avoid colliding with existing system's DB=0) ─
REDIS_URL=redis://localhost:6379
REDIS_DB=1
REDIS_ENABLED=true
REDIS_CHAT_TTL=86400

# ── Al Hafiz Electronics — Business Identity ─────────────────────────────────
BUSINESS_NAME=Al Hafiz Electronics
BUSINESS_TAGLINE=آپ کا قابل اعتماد الیکٹرونکس اسٹور
BUSINESS_ADDRESS=گلشن اقبال، کراچی (اپنا پتہ یہاں لکھیں)
BUSINESS_HOURS=پیر تا اتوار، صبح 10 بجے سے رات 9 بجے
OWNER_WHATSAPP=+923001234567   # owner's number — gets notified on every new order

# ── Webhook Verification ──────────────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=whatsapp_ai_verify

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Rule Engine (customize Urdu replies per keyword) ─────────────────────────
# These override the defaults in config/settings.py
# REPLY_PRICE=💰 ہماری فیس یہاں درج کریں
# REPLY_LOCATION=📍 ہمارا پتہ یہاں
# REPLY_TIMING=🕐 وقت یہاں

# ── Agent Escalation ──────────────────────────────────────────────────────────
ESCALATION_THRESHOLD_TURNS=3

# ── Broadcast ────────────────────────────────────────────────────────────────
BROADCAST_BATCH_SIZE=10
BROADCAST_DELAY_SECONDS=1.0
