# Flask configuration
FLASK_ENV=production
FLASK_APP=app.py
AI_LAYER_PORT=5000

# Redis configuration (internal docker network)
REDIS_URL=redis://redis:6379
REDIS_DB=1
REDIS_CHAT_TTL=86400
REDIS_ENABLED=True

# NestJS Integration URL (production URL)
NESTJS_BASE_URL=http://your_nestjs_host:3005/api

# Twilio configuration
TWILIO_ACCOUNT_SID=your_production_account_sid
TWILIO_AUTH_TOKEN=your_production_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# Owner Notification (comma-separated if multiple, optional)
OWNER_WHATSAPP=whatsapp:+923001234567

# OpenAI Configuration
OPENAI_API_KEY=your_production_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=300

# AI Prompts & Thresholds
AI_SYSTEM_PROMPT="You are Al Hafiz Electronics' AI assistant. Answer in Urdu. Be polite."
ESCALATION_THRESHOLD_TURNS=4
